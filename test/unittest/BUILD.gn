import("//build/ohos.gni")
import("//build/test.gni")

# 本目录下多个 ohos_unittest 共用的 include / 编译宏；目标级字段见各 ohos_unittest 块。
config("disk_manager_unittest_common") {
  include_dirs = [
    "//foundation/filemanagement/disk_manager/services/disk_manager/include",
    "//foundation/filemanagement/disk_manager/interfaces/innerkits/include",
  ]
  defines = [
    "DISK_MANAGER_LOG_TAG = \"DiskManager\"",
    "LOG_DOMAIN = 0xD00430F",
  ]
}

ohos_unittest("disk_manager_common_event_publisher_test") {
  module_out_path = "/disk_manager/disk_manager"
  use_exceptions = true

  sources = [
    "common_event_publisher_test.cpp",
    "//foundation/filemanagement/disk_manager/services/disk_manager/src/notification/common_event_publisher.cpp",
  ]

  configs = [
    ":disk_manager_unittest_common",
    "//foundation/filemanagement/disk_manager/common:disk_manager_common_include",
    "//foundation/filemanagement/disk_manager/utils:disk_manager_utils_include",
  ]

  deps = [
    "//foundation/filemanagement/disk_manager/interfaces/innerkits:disk_manager_innerkits",
  ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "googletest:gtest_main",
    "hilog:libhilog",
  ]

  subsystem_name = "filemanagement"
  part_name = "disk_manager"
}

group("disk_manager_ut") {
  testonly = true
  deps = [ ":disk_manager_common_event_publisher_test" ]
}
